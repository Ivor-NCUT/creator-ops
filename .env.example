DATABASE_URL=postgresql://creator_ops:creator_ops@localhost:5433/creator_ops
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
AUTOMATION_SECRET=replace-with-an-independent-32-character-secret
POSTGRES_DB=creator_ops
POSTGRES_USER=creator_ops
# 本地默认值与 DATABASE_URL 一致；生产部署必须同时换成强密码。
POSTGRES_PASSWORD=creator_ops
APP_PORT=3000
