generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  timezone      String         @default("Asia/Shanghai")
  locale        String         @default("zh-CN")
  currency      String         @default("CNY")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  departments   Department[]
  members       Member[]
  auditEvents   AuditEvent[]
  files         FileMetadata[]
  notifications Notification[]
  projects      Project[]
  tasks         Task[]
  aiRequests    AiRequest[]
  contentProfiles ContentProfile[]
  publishingAccounts PublishingAccount[]
  contentItems  ContentItem[]
  publications  Publication[]
  workEvents    WorkEvent[]
}

enum SystemRole {
  OWNER
  ADMIN
  HR
  FINANCE
  MANAGER
  MEMBER
  VIEWER
}

enum MemberStatus {
  ACTIVE
  DISABLED
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  member        Member?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  members        Member[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Member {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userId         String         @unique
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  departmentId   String?
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role           SystemRole     @default(MEMBER)
  status         MemberStatus   @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  auditEvents    AuditEvent[]   @relation("AuditActor")
  notifications  Notification[]
  ownedProjects  Project[]            @relation("ProjectOwner")
  projectMemberships ProjectMember[]
  assignedTasks  Task[]               @relation("TaskAssignee")
  requestedAiRequests AiRequest[]      @relation("AiRequester")
  ownedAiRequests AiRequest[]          @relation("AiOwner")
  ownedContent   ContentItem[]         @relation("ContentOwner")
  contentStatusChanges ContentStatusHistory[]
  contentAssignments ContentAssignment[]
  workEvents     WorkEvent[]

  @@index([organizationId, role])
  @@index([departmentId])
}

enum WorkStatus {
  PLANNED
  ACTIVE
  BLOCKED
  DONE
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  description    String?
  status         WorkStatus   @default(PLANNED)
  priority       Priority     @default(NORMAL)
  ownerId        String
  owner          Member       @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  startsAt       DateTime?
  dueAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  members        ProjectMember[]
  tasks          Task[]
  aiRequests     AiRequest[]
  contentItems   ContentItem[]

  @@index([organizationId, status, dueAt])
}

model ProjectMember {
  projectId String
  memberId  String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    Member  @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@id([projectId, memberId])
  @@index([memberId])
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  parentId       String?
  parent         Task?        @relation("TaskChildren", fields: [parentId], references: [id], onDelete: Restrict)
  children       Task[]       @relation("TaskChildren")
  title          String
  description    String?
  status         WorkStatus   @default(PLANNED)
  priority       Priority     @default(NORMAL)
  assigneeId     String?
  assignee       Member?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  dueAt          DateTime?
  completedAt    DateTime?
  points         Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status, dueAt])
  @@index([projectId, parentId])
  @@index([assigneeId])
}

enum AiRequestStatus {
  SUBMITTED
  TRIAGED
  IN_PROGRESS
  VALIDATING
  DELIVERED
  REJECTED
}

model AiRequest {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  title          String
  problem        String
  expectedOutcome String
  status         AiRequestStatus @default(SUBMITTED)
  priority       Priority        @default(NORMAL)
  requesterId    String
  requester      Member          @relation("AiRequester", fields: [requesterId], references: [id], onDelete: Restrict)
  ownerId        String?
  owner          Member?         @relation("AiOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  dueAt          DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, status, dueAt])
  @@index([requesterId])
  @@index([ownerId])
}

enum ContentType {
  VIDEO
  ARTICLE
  BOOK
}

enum ContentStatus {
  IDEA
  READY_TO_SHOOT
  ROUGH_CUT
  FINE_CUT
  REVIEW
  RETAKE
  REJECTED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model ContentProfile {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  contentItems   ContentItem[]

  @@unique([organizationId, name])
}

model PublishingAccount {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  name           String
  channel        String
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  publications   Publication[]

  @@unique([organizationId, channel, name])
}

model ContentItem {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Restrict)
  profileId      String?
  profile        ContentProfile? @relation(fields: [profileId], references: [id], onDelete: Restrict)
  ownerId        String
  owner          Member       @relation("ContentOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  type           ContentType
  title          String
  summary        String?
  status         ContentStatus @default(IDEA)
  priority       Priority      @default(NORMAL)
  plannedAt      DateTime?
  dueAt          DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  video          VideoDetail?
  editorial      EditorialDetail?
  statusHistory  ContentStatusHistory[]
  assignments    ContentAssignment[]
  publications   Publication[]
  workEvents     WorkEvent[]

  @@index([organizationId, type, status, plannedAt])
  @@index([ownerId])
}

model VideoDetail {
  contentId       String      @id
  content         ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  scriptUrl       String?
  footageUrl      String?
  workloadPoints  Int         @default(1)
  slaStartedAt    DateTime?
}

model EditorialDetail {
  contentId       String      @id
  content         ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  topic           String?
  manuscriptUrl   String?
  workloadPoints  Int         @default(1)
}

enum ContentAssignmentRole {
  OWNER
  DIRECTOR
  EDITOR
  WRITER
  REVIEWER
}

model ContentAssignment {
  contentId String
  memberId  String
  role      ContentAssignmentRole
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  member    Member      @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@id([contentId, memberId, role])
  @@index([memberId, role])
}

model ContentStatusHistory {
  id          String        @id @default(cuid())
  contentId   String
  content     ContentItem   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  fromStatus  ContentStatus?
  toStatus    ContentStatus
  actorId     String
  actor       Member        @relation(fields: [actorId], references: [id], onDelete: Restrict)
  note        String?
  createdAt   DateTime      @default(now())

  @@index([contentId, createdAt])
  @@index([actorId, createdAt])
}

model Publication {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contentId      String
  content        ContentItem  @relation(fields: [contentId], references: [id], onDelete: Restrict)
  accountId      String
  account        PublishingAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  publishedAt    DateTime
  url            String?
  createdAt      DateTime     @default(now())
  metricSnapshots PublicationMetricSnapshot[]

  @@unique([contentId, accountId, publishedAt])
  @@index([organizationId, publishedAt])
}

model PublicationMetricSnapshot {
  id            String      @id @default(cuid())
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  capturedAt    DateTime
  views         Int         @default(0)
  likes         Int         @default(0)
  comments      Int         @default(0)
  shares        Int         @default(0)
  followers     Int?
  createdAt     DateTime    @default(now())

  @@unique([publicationId, capturedAt])
  @@index([capturedAt])
}

enum WorkEventType {
  CONTENT_CREATED
  CONTENT_TRANSITION
  CONTENT_PUBLISHED
}

model WorkEvent {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  memberId       String
  member         Member        @relation(fields: [memberId], references: [id], onDelete: Restrict)
  contentId      String
  content        ContentItem   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  type           WorkEventType
  points         Int
  occurredAt     DateTime      @default(now())

  @@index([organizationId, occurredAt])
  @@index([memberId, occurredAt])
}

model AuditEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  actorId        String?
  actor          Member?      @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

model FileMetadata {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  storageKey     String       @unique
  originalName   String
  contentType    String
  sizeBytes      BigInt
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  recipientId    String
  recipient      Member       @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  title          String
  body           String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([recipientId, readAt, createdAt])
}
